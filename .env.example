ANTHROPIC_API_KEY=sk-ant-...
VIGIL_PROJECT_PROMPT="Building a payment processing microservice. JWT auth on all /api/v1/ routes. Admin panel at /admin/*. Payment data must never be logged. PostgreSQL backend."

# Minimum severity to trigger a BLOCK. Findings below this become WARN (logged but not blocking).
# Valid values: LOW, MEDIUM, HIGH, CRITICAL. Default: LOW (blocks everything).
VIGIL_MIN_BLOCK_SEVERITY=LOW
